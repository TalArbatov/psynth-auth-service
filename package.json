{
    "name": "psynth-authentication-service",
    "version": "1.0.0",
    "main": "index.js",
    "scripts": {
        "start": "DOTENV_PATH=.env.production NODE_ENV=production node dist/web-server",
        "build": "rm -rf dist && tsc",
        "dev": "concurrently \"tsc --watch\" \"nodemon dist/web-server\"",
        "test": "vitest run",
        "test:watch": "vitest",
        "coverage": "vitest run --coverage",
        "deploy": "./scripts/deploy.sh",
        "db:migrate": "drizzle-kit migrate",
        "db:migrate:prod": "DOTENV_PATH=.env.production drizzle-kit migrate",
        "db:reset-local": "ALLOW_LOCAL_DB_RESET=true node ./scripts/db/reset-local-migrations.js",
        "db:push": "drizzle-kit push",
        "db:generate": "drizzle-kit generate",
        "db:studio": "drizzle-kit studio"
    },
    "keywords": [],
    "author": "Tal Arbetov",
    "license": "MIT",
    "description": "Psynth Authentication Service",
    "devDependencies": {
        "@types/bcrypt": "^6.0.0",
        "@types/config": "^3.3.5",
        "@types/node": "^25.0.9",
        "@types/pg": "^8.16.0",
        "@vitest/coverage-v8": "^4.0.17",
        "concurrently": "^9.2.1",
        "drizzle-kit": "^0.31.9",
        "nodemon": "^3.1.11",
        "typescript": "^5.9.3",
        "vitest": "^4.0.17"
    },
    "dependencies": {
        "@fastify/cookie": "^11.0.2",
        "@fastify/cors": "^11.2.0",
        "@fastify/sensible": "^6.0.4",
        "bcrypt": "^6.0.0",
        "config": "^4.2.0",
        "dotenv": "^17.2.3",
        "drizzle-orm": "^0.45.1",
        "fastify": "^5.7.1",
        "nanoid": "^3.3.4",
        "pg": "^8.17.1"
    }
}